{
  "name": "cleancode-deploy",
  "displayName": "cleancode-deploy",
  "description": "Universal deployment cleanup extension for all programming languages and tools.",
  "version": "0.0.1",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
"contributes": {
  "commands": [
    {
      "command": "cleancode-deploy.helloWorld",
      "title": "Hello World"
    },
    {
      "command": "cleancode-deploy.scanWorkspace",
      "title": "CleanCode Deploy: Scan Workspace"
    },
    {
      "command": "cleancode-deploy.listRules",
      "title": "CleanCode Deploy: List Rules"
    },
    {
      "command": "cleancode-deploy.openIssue",
      "title": "CleanCode Deploy: Open Issue"
    }
  ],
  "viewsContainers": {
    "activitybar": [
      {
        "id": "cleancodeDeploy",
        "title": "CleanCode Deploy",
        "icon": "resources/icon.svg"
      }
    ]
  },
  "views": {
    "cleancodeDeploy": [
      {
        "id": "cleancodeDeploy.issueExplorer",
        "name": "Issue Explorer"
      }
    ]
  },
  "configuration": {
    "title": "CleanCode Deploy",
    "properties": {
      "cleancodeDeploy.rules.consoleLog": {
        "type": "boolean",
        "default": true,
        "description": "Detect console.log statements."
      }
    }
  }
},
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "ts-loader": "^9.6.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
