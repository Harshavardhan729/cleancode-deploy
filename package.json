{
  "name": "cleancode-deploy",
  "displayName": "cleancode-deploy",
  "description": "Universal deployment cleanup extension for all programming languages and tools.",
  "version": "0.0.1",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cleancode-deploy.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "cleancode-deploy.scanWorkspace",
        "title": "CleanCode Deploy: Scan Workspace",
        "icon": "$(refresh)"
      },
      {
        "command": "cleancode-deploy.listRules",
        "title": "CleanCode Deploy: List Rules"
      },
      {
        "command": "cleancode-deploy.openIssue",
        "title": "CleanCode Deploy: Open Issue"
      },
      {
        "command": "cleancode-deploy.clearIssues",
        "title": "CleanCode Deploy: Clear Issues",
        "icon": "$(clear-all)"
      },
      {
        "command": "cleancode-deploy.reloadConfiguration",
        "title": "CleanCode Deploy: Reload Configuration",
        "icon": "$(sync)"
      },
      {
        "command": "cleancode-deploy.showStatistics",
        "title": "CleanCode Deploy: Show Statistics",
        "icon": "$(graph)"
      },
      {
        "command": "cleancode-deploy.previewHtmlReport",
        "title": "CleanCode Deploy: Preview HTML Report",
        "icon": "$(preview)"
      },
      {
        "command": "cleancode-deploy.exportHtmlReport",
        "title": "CleanCode Deploy: Export HTML Report",
        "icon": "$(save)"
      },
      {
        "command": "cleancode-deploy.autoFixWorkspace",
        "title": "CleanCode Deploy: Auto Fix Workspace",
        "icon": "$(tools)"
      },
      {
        "command": "cleancode-deploy.openBackupFolder",
        "title": "CleanCode Deploy: Open Backup Folder",
        "icon": "$(folder-opened)"
      },
      {
        "command": "cleancode-deploy.restoreBackup",
        "title": "CleanCode Deploy: Restore Backup",
        "icon": "$(history)"
      },
      {
        "command": "cleancode-deploy.clearBackups",
        "title": "CleanCode Deploy: Clear Backups",
        "icon": "$(trash)"
      },
      {
        "command": "cleancode-deploy.showAutoFixStatistics",
        "title": "CleanCode Deploy: Show Auto Fix Statistics",
        "icon": "$(graph-line)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cleancodeDeploy",
          "title": "CleanCode Deploy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cleancodeDeploy": [
        {
          "id": "cleancodeDeploy.issueExplorer",
          "name": "Issue Explorer"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "cleancode-deploy.openIssue",
          "when": "view == cleancodeDeploy.issueExplorer && viewItem == issue",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "cleancode-deploy.scanWorkspace",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.autoFixWorkspace",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.restoreBackup",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.clearBackups",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.showStatistics",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.previewHtmlReport",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.exportHtmlReport",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        },
        {
          "command": "cleancode-deploy.clearIssues",
          "when": "view == cleancodeDeploy.issueExplorer",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CleanCode Deploy",
      "order": 1,
      "properties": {
        "cleancodeDeploy.autoFix.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Auto Fix functionality."
        },
        "cleancodeDeploy.autoFix.previewOnly": {
          "type": "boolean",
          "default": false,
          "description": "Preview Auto Fix results without modifying workspace files."
        },
        "cleancodeDeploy.autoFix.profile": {
          "type": "string",
          "enum": [
            "Conservative",
            "Balanced",
            "Aggressive"
          ],
          "default": "Conservative",
          "description": "Select the Auto Fix profile."
        },
        "cleancodeDeploy.backup.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Create backup files before applying Auto Fix."
        },
        "cleancodeDeploy.rules.consoleLog": {
          "type": "boolean",
          "default": true,
          "description": "Detect console.log statements."
        },
        "cleancodeDeploy.rules.debugger": {
          "type": "boolean",
          "default": true,
          "description": "Detect debugger statements."
        },
        "cleancodeDeploy.rules.alert": {
          "type": "boolean",
          "default": true,
          "description": "Detect alert() statements."
        },
        "cleancodeDeploy.rules.todo": {
          "type": "boolean",
          "default": true,
          "description": "Detect TODO comments."
        },
        "cleancodeDeploy.rules.fixme": {
          "type": "boolean",
          "default": true,
          "description": "Detect FIXME comments."
        },
        "cleancodeDeploy.rules.commentedCode": {
          "type": "boolean",
          "default": true,
          "description": "Detect commented-out code."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "ts-loader": "^9.6.2",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}